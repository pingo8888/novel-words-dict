{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "name-dict",
  "version": "0.1.1",
  "identifier": "com.local.name-dict",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "小说词库",
        "width": 1320,
        "height": 1140,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "resources": [
      "../dict"
    ],
    "windows": {
      "nsis": {
        "template": "installer.nsi"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
