{
  "productName": "novel-words-dict",
  "version": "0.1.6",
  "identifier": "com.local.novel-words-dict",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "小说词库",
        "width": 1278,
        "height": 928,
        "resizable": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset:; style-src 'self'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:; media-src 'self' blob:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "nsis",
    "resources": [
      "../build-in.db"
    ],
    "windows": {
      "nsis": {
        "template": "installer.nsi"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/pingo8888/novel-words-dict/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGRTkwNjc3NzI0MkE5MDMKUldRRHFVSnlkd2JwbnlaY2lBY0YyZWxpOWdVaTNOZlNVVUdEUUlvVnBlWjY1L3FScWZrR1Q3czQK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
